# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored and never committed.
#
# Used locally via `node --env-file=.env.local ...` (npm start / dev / seed).
# On Vercel, set these same variables under Project Settings -> Environment
# Variables instead (do NOT commit real keys).

# --- Supabase (server-side only) ---
# From https://supabase.com/dashboard -> your project -> Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Supabase (browser; exposed to the web app at build time) ---
# The anon (public) key is safe to ship to the browser — it can only do anything
# with valid credentials, and Row Level Security blocks direct data access. Vite
# only inlines variables prefixed with VITE_. Use the SAME project URL as above.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
